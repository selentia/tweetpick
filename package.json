{
  "name": "tweet-pick",
  "version": "0.1.2",
  "private": true,
  "description": "TweetPick for X (Twitter)",
  "author": "selentia",
  "license": "Apache-2.0",
  "type": "commonjs",
  "engines": {
    "node": ">=22.13 <23"
  },
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "npm run build && electron .",
    "clean": "rimraf dist dist-tests release coverage",
    "format": "prettier --write .",
    "lint": "eslint --max-warnings=0 \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.mjs\" \"vitest.config.ts\" \"eslint.config.mjs\"",
    "typecheck": "tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p tsconfig.renderer.json && tsc --noEmit -p tsconfig.tests.json",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "build": "rimraf dist && node scripts/generate-win-icon.mjs && node scripts/sync-build-twitter-config.mjs && node scripts/sync-ipc-channels.mjs && node scripts/check-ipc-sync.mjs && npm run typecheck && tsc -p tsconfig.renderer.json && tsc-alias -p tsconfig.renderer.json && tsc -p tsconfig.main.json && tsc-alias -p tsconfig.main.json && node scripts/check-dist-module-format.mjs && node scripts/check-preload-sandbox-safety.mjs && node scripts/copy-renderer-assets.mjs",
    "dist": "node scripts/run-dist.mjs",
    "verify": "npm run lint && npm run typecheck && node scripts/check-ipc-sync.mjs && npm run test:coverage"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.13.0",
    "@vitest/coverage-v8": "^3.2.4",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "sharp": "^0.34.5",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.2.4"
  },
  "build": {
    "appId": "com.tweetpick.app",
    "productName": "TweetPick",
    "artifactName": "${productName}.${ext}",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "!dist/**/*.map",
      "package.json",
      "LICENSE",
      "NOTICE",
      "README.md"
    ],
    "win": {
      "icon": "icon.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "extraResources": [
      {
        "from": "build/twitter-config.json",
        "to": "twitter-config.json"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/selentia/tweetpick.git"
  },
  "homepage": "https://github.com/selentia/tweetpick"
}
